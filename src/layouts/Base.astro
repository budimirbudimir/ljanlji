---
import Header from '@/components/layout/Header.astro'
import Footer from '@/components/layout/Footer.astro'
import { type Locale } from '@/i18n/ui'
import '@/styles/global.css'

interface Props {
  locale: Locale
  title: string
  description?: string
  ogImage?: string
}

const {
  locale,
  title,
  description = 'Ljanlji — ručni rad iz srca Balkana. Sušeno cvijeće, uskršnje korpe i sezonski dekor.',
  ogImage = '/og-image.jpg',
} = Astro.props

const langMap: Record<Locale, string> = {
  bs: 'bs',
  sr: 'sr-Cyrl',
  de: 'de',
  en: 'en',
}
---

<!doctype html>
<html lang={langMap[locale]} dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Ljanlji</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={`${title} — Ljanlji`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />

    <div class="font-size-widget" aria-label="Veličina teksta">
      <button class="fs-btn" id="fs-down" aria-label="Manji tekst" title="Manji tekst">A−</button>
      <button class="fs-btn" id="fs-up" aria-label="Veći tekst" title="Veći tekst">A+</button>
    </div>

    <script>
      const steps = ['', 'lg', 'xl']
      const html = document.documentElement
      let current = steps.indexOf(localStorage.getItem('text-size') || '')
      if (current < 0) current = 0
      if (steps[current]) html.setAttribute('data-text', steps[current])

      document.getElementById('fs-up')?.addEventListener('click', () => {
        if (current < steps.length - 1) current++
        const val = steps[current]
        val ? html.setAttribute('data-text', val) : html.removeAttribute('data-text')
        localStorage.setItem('text-size', val)
      })
      document.getElementById('fs-down')?.addEventListener('click', () => {
        if (current > 0) current--
        const val = steps[current]
        val ? html.setAttribute('data-text', val) : html.removeAttribute('data-text')
        localStorage.setItem('text-size', val)
      })
    </script>
  </body>
</html>

<style>
  .font-size-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    display: flex;
    gap: 4px;
    z-index: 200;
  }

  .fs-btn {
    background: var(--dark);
    color: var(--mustard);
    border: none;
    border-radius: var(--radius-sm);
    padding: 8px 11px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    opacity: 0.72;
    transition: opacity 0.15s;
    line-height: 1;
  }

  .fs-btn:hover { opacity: 1; }
</style>
