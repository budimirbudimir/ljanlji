---
export const prerender = true
import Base from '@/layouts/Base.astro'
import { t, locales, type Locale } from '@/i18n/ui'
import { pick } from '@/lib/content'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../../keystatic.config'

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params as { lang: Locale }

const reader = createReader(process.cwd(), keystaticConfig)

// Featured products
const allProducts = await reader.collections.products.all()
const featured = allProducts
  .filter((p) => p.entry.status === 'published' && p.entry.featured)
  .slice(0, 3)

// Home page singleton
const homePage = await reader.singletons.homePage.read()
const heroTitle = homePage ? pick(homePage.heroTitle as any, lang) : t(lang, 'hero.title')
const heroSubtitle = homePage ? pick(homePage.heroSubtitle as any, lang) : t(lang, 'hero.subtitle')
const heroCta = homePage ? pick(homePage.heroCta as any, lang) : t(lang, 'hero.cta')
---

<Base locale={lang} title={heroTitle || 'Ljanlji'}>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <span class="eyebrow">{t(lang, 'hero.subtitle').split('—')[0]}</span>
        <h1 class="hero-title" set:html={heroTitle.replace(/([^.!?]+[.!?]?\s*)/g, '$1')} />
        <p class="hero-sub">{heroSubtitle}</p>
        <a href={`/${lang}/products`} class="btn-primary">{heroCta} →</a>
      </div>
      <div class="hero-art" aria-hidden="true">
        <!-- Naive-art folk flower basket SVG -->
        <svg viewBox="0 0 220 220" fill="none" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="110" cy="158" rx="58" ry="18" fill="#8B5A2B" opacity="0.85"/>
          <path d="M52 142 Q52 178 110 180 Q168 178 168 142 L160 128 Q144 118 110 118 Q76 118 60 128 Z" fill="#B07040"/>
          <path d="M60 128 Q110 138 160 128" stroke="#8B5A2B" stroke-width="1.8" opacity="0.5"/>
          <path d="M54 142 Q110 155 166 142" stroke="#8B5A2B" stroke-width="1.8" opacity="0.5"/>
          <path d="M56 156 Q110 168 164 156" stroke="#8B5A2B" stroke-width="1.8" opacity="0.5"/>
          <line x1="110" y1="118" x2="110" y2="78" stroke="#5A9060" stroke-width="2.5"/>
          <line x1="110" y1="108" x2="80" y2="72" stroke="#5A9060" stroke-width="2"/>
          <line x1="110" y1="108" x2="140" y2="72" stroke="#5A9060" stroke-width="2"/>
          <line x1="110" y1="100" x2="62" y2="84" stroke="#5A9060" stroke-width="1.8"/>
          <line x1="110" y1="100" x2="158" y2="84" stroke="#5A9060" stroke-width="1.8"/>
          <line x1="110" y1="95" x2="92" y2="62" stroke="#5A9060" stroke-width="1.5"/>
          <line x1="110" y1="95" x2="128" y2="62" stroke="#5A9060" stroke-width="1.5"/>
          <ellipse cx="96" cy="84" rx="9" ry="4" fill="#5A9060" transform="rotate(-35 96 84)" opacity="0.9"/>
          <ellipse cx="124" cy="84" rx="9" ry="4" fill="#5A9060" transform="rotate(35 124 84)" opacity="0.9"/>
          <ellipse cx="72" cy="96" rx="8" ry="3" fill="#5A9060" transform="rotate(-50 72 96)" opacity="0.8"/>
          <ellipse cx="148" cy="96" rx="8" ry="3" fill="#5A9060" transform="rotate(50 148 96)" opacity="0.8"/>
          <circle cx="110" cy="70" r="10" fill="#C4622D"/>
          <circle cx="110" cy="57" r="7" fill="#E8B84B"/>
          <circle cx="121" cy="62" r="7" fill="#E8B84B"/>
          <circle cx="121" cy="75" r="7" fill="#E8B84B"/>
          <circle cx="110" cy="82" r="7" fill="#E8B84B"/>
          <circle cx="99" cy="75" r="7" fill="#E8B84B"/>
          <circle cx="99" cy="62" r="7" fill="#E8B84B"/>
          <circle cx="110" cy="70" r="8" fill="#C4622D"/>
          <circle cx="110" cy="70" r="4" fill="#E8B84B"/>
          <circle cx="80" cy="62" r="8" fill="#C9706A"/>
          <circle cx="80" cy="51" r="5" fill="#FAF3E8"/>
          <circle cx="90" cy="56" r="5" fill="#FAF3E8"/>
          <circle cx="90" cy="67" r="5" fill="#FAF3E8"/>
          <circle cx="80" cy="72" r="5" fill="#FAF3E8"/>
          <circle cx="70" cy="67" r="5" fill="#FAF3E8"/>
          <circle cx="70" cy="56" r="5" fill="#FAF3E8"/>
          <circle cx="80" cy="62" r="5.5" fill="#C9706A"/>
          <circle cx="80" cy="62" r="2.5" fill="#FAF3E8"/>
          <circle cx="140" cy="62" r="8" fill="#5A9060"/>
          <circle cx="140" cy="51" r="5" fill="#E8B84B"/>
          <circle cx="150" cy="56" r="5" fill="#E8B84B"/>
          <circle cx="150" cy="67" r="5" fill="#E8B84B"/>
          <circle cx="140" cy="72" r="5" fill="#E8B84B"/>
          <circle cx="130" cy="67" r="5" fill="#E8B84B"/>
          <circle cx="130" cy="56" r="5" fill="#E8B84B"/>
          <circle cx="140" cy="62" r="5.5" fill="#5A9060"/>
          <circle cx="140" cy="62" r="2.5" fill="#FAF3E8"/>
          <circle cx="65" cy="80" r="6" fill="#E8B84B"/>
          <circle cx="65" cy="73" r="3.5" fill="#FAF3E8"/>
          <circle cx="71" cy="76" r="3.5" fill="#FAF3E8"/>
          <circle cx="71" cy="84" r="3.5" fill="#FAF3E8"/>
          <circle cx="65" cy="87" r="3.5" fill="#FAF3E8"/>
          <circle cx="59" cy="84" r="3.5" fill="#FAF3E8"/>
          <circle cx="59" cy="76" r="3.5" fill="#FAF3E8"/>
          <circle cx="65" cy="80" r="3" fill="#E8B84B"/>
          <circle cx="155" cy="80" r="6" fill="#C4622D"/>
          <circle cx="155" cy="73" r="3.5" fill="#FAF3E8"/>
          <circle cx="161" cy="76" r="3.5" fill="#FAF3E8"/>
          <circle cx="161" cy="84" r="3.5" fill="#FAF3E8"/>
          <circle cx="155" cy="87" r="3.5" fill="#FAF3E8"/>
          <circle cx="149" cy="84" r="3.5" fill="#FAF3E8"/>
          <circle cx="149" cy="76" r="3.5" fill="#FAF3E8"/>
          <circle cx="155" cy="80" r="3" fill="#C4622D"/>
          <circle cx="92" cy="50" r="2.5" fill="#E8B84B"/>
          <circle cx="128" cy="50" r="2.5" fill="#C9706A"/>
          <circle cx="110" cy="44" r="3" fill="#5A9060"/>
          <circle cx="76" cy="46" r="2" fill="#C4622D"/>
          <circle cx="144" cy="46" r="2" fill="#C4622D"/>
        </svg>
      </div>
    </div>
  </section>

  <div class="folk-band"></div>

  <!-- FEATURED PRODUCTS -->
  {featured.length > 0 && (
    <section class="section featured-section">
      <span class="eyebrow">{t(lang, 'nav.products')}</span>
      <h2 class="section-title">{t(lang, 'products.title')}</h2>
      <div class="product-grid">
        {featured.map((product) => {
          const coverImage = product.entry.images?.[0] ?? null
          const title = pick(product.entry.title as any, lang)
          return (
            <a href={`/${lang}/products/${product.slug}`} class="product-card">
              <div class="product-img-wrap">
                {coverImage ? (
                  <img src={coverImage} alt={title} loading="lazy" class="product-img" />
                ) : (
                  <div class="product-img-placeholder" />
                )}
              </div>
              <div class="product-info">
                <span class="tag">{t(lang, `cat.${product.entry.category}` as any)}</span>
                <h3 class="product-name">{title}</h3>
                <span class="product-link">{t(lang, 'products.viewProduct')} →</span>
              </div>
            </a>
          )
        })}
      </div>
      <div class="all-link-wrap">
        <a href={`/${lang}/products`} class="btn-outline">{t(lang, 'products.title')} →</a>
      </div>
    </section>
  )}

  <div class="folk-band"></div>

  <!-- ABOUT TEASER -->
  <section class="about-teaser">
    <div class="about-teaser-inner section">
      <div class="about-teaser-text">
        <span class="eyebrow">{t(lang, 'about.title')}</span>
        <h2 class="section-title" style="color:#fff">Ljanlji</h2>
        <p class="about-teaser-body">
          {lang === 'bs' && 'Svaki komad nastaje u tišini, rukom i srcem. Inspiracija dolazi iz seoskog života Balkana — sa polja, iz bašte, iz tradicije koja se prenosi s koljena na koljeno.'}
          {lang === 'sr' && 'Сваки комад настаје у тишини, руком и срцем. Инспирација долази из сеоског живота Балкана — са поља, из баште, из традиције која се преноси с кољена на кољено.'}
          {lang === 'de' && 'Jedes Stück entsteht in der Stille, mit Hand und Herz. Die Inspiration kommt aus dem Landleben des Balkans — von den Feldern, aus dem Garten, aus einer Tradition, die von Generation zu Generation weitergegeben wird.'}
          {lang === 'en' && 'Every piece is made in silence, by hand and heart. The inspiration comes from rural Balkan life — from the fields, from the garden, from a tradition passed down through generations.'}
        </p>
        <a href={`/${lang}/about`} class="btn-primary" style="background:var(--mustard);color:var(--dark)">{t(lang, 'about.title')} →</a>
      </div>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="section contact-cta">
    <div class="contact-cta-inner">
      <p class="contact-cta-text">
        {lang === 'bs' && 'Zainteresovani?'}
        {lang === 'sr' && 'Заинтересовани?'}
        {lang === 'de' && 'Interessiert?'}
        {lang === 'en' && 'Interested?'}
        {' '}
        <span>
          {lang === 'bs' && 'Pišite nam.'}
          {lang === 'sr' && 'Пишите нам.'}
          {lang === 'de' && 'Schreiben Sie uns.'}
          {lang === 'en' && 'Get in touch.'}
        </span>
      </p>
      <a href={`/${lang}/contact`} class="btn-outline">{t(lang, 'contact.title')} →</a>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  .hero {
    background: var(--paper);
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    right: -80px;
    top: -80px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232,184,75,0.18) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 72px 48px 64px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: clamp(32px, 5vw, 52px);
    color: var(--dark);
    margin: 12px 0 18px;
    line-height: 1.15;
  }

  .hero-title em { color: var(--terracotta); }

  .hero-sub {
    font-size: 14px;
    color: var(--mid);
    line-height: 1.75;
    margin-bottom: 30px;
    max-width: 380px;
  }

  .hero-art svg {
    width: 100%;
    max-width: 300px;
    margin: 0 auto;
    display: block;
  }

  /* FEATURED */
  .featured-section { padding-top: 56px; padding-bottom: 56px; }

  .section-title {
    font-size: clamp(22px, 3vw, 30px);
    color: var(--dark);
    margin-bottom: 32px;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 36px;
  }

  .product-card {
    background: #fff;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(90,144,96,0.15);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s, transform 0.2s;
    display: block;
  }

  .product-card:hover {
    box-shadow: 0 8px 28px rgba(58,32,16,0.14);
    transform: translateY(-2px);
  }

  .product-img-wrap { overflow: hidden; aspect-ratio: 4/3; }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .product-card:hover .product-img { transform: scale(1.04); }

  .product-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--paper) 0%, var(--brown-paper) 100%);
  }

  .product-info { padding: 14px 16px 18px; }

  .product-name {
    font-size: 16px;
    color: var(--dark);
    margin: 8px 0 10px;
  }

  .product-link {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--terracotta);
    font-weight: 600;
  }

  .all-link-wrap { text-align: center; }

  /* ABOUT TEASER */
  .about-teaser {
    background: linear-gradient(135deg, var(--sage-dark) 0%, var(--sage) 100%);
  }

  .about-teaser-body {
    font-size: 14px;
    color: #fff;
    opacity: 0.88;
    line-height: 1.82;
    margin-bottom: 28px;
    max-width: 520px;
  }

  /* CONTACT CTA */
  .contact-cta { padding-top: 40px; padding-bottom: 40px; }

  .contact-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    background: var(--paper);
    border-radius: var(--radius-md);
    padding: 28px 36px;
    flex-wrap: wrap;
  }

  .contact-cta-text {
    font-family: var(--font-heading);
    font-size: 22px;
    color: var(--dark);
  }

  .contact-cta-text span { color: var(--terracotta); font-style: italic; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; padding: 48px 20px; }
    .hero-art { display: none; }
    .product-grid { grid-template-columns: 1fr; }
    .contact-cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
