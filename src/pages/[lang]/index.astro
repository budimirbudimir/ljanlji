---
export const prerender = true
import Base from '@/layouts/Base.astro'
import { t, locales, type Locale } from '@/i18n/ui'
import { pick } from '@/lib/content'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../../keystatic.config'

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params as { lang: Locale }

const reader = createReader(process.cwd(), keystaticConfig)

// Featured products
const allProducts = await reader.collections.products.all()
const published = allProducts
  .filter((p) => p.entry.status === 'published')
  .sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0))
const featured = published.filter((p) => p.entry.featured).slice(0, 3)
const heroImage = featured[0]?.entry.images?.[0] ?? published[0]?.entry.images?.[0] ?? null

// Home page singleton
const homePage = await reader.singletons.homePage.read()
const heroTitle = homePage ? pick(homePage.heroTitle as any, lang) : t(lang, 'hero.title')
const heroSubtitle = homePage ? pick(homePage.heroSubtitle as any, lang) : t(lang, 'hero.subtitle')
const heroCta = homePage ? pick(homePage.heroCta as any, lang) : t(lang, 'hero.cta')
---

<Base locale={lang} title={heroTitle || 'Ljanlji'}>
  <!-- HERO -->
  <section class="hero">
    {heroImage && (
      <div class="hero-bg" aria-hidden="true">
        <img class="hero-bg-sharp" src={heroImage} alt="" />
        <div class="hero-bg-blur">
          <img class="hero-bg-blur-img" src={heroImage} alt="" />
        </div>
      </div>
    )}
    <div class="hero-overlay" aria-hidden="true" />
    <div class="hero-inner">
      <div class="hero-text">
        <span class="eyebrow">{t(lang, 'hero.subtitle').split('—')[0]}</span>
        <h1 class="hero-title" set:html={heroTitle.replace(/([^.!?]+[.!?]?\s*)/g, '$1')} />
        <p class="hero-sub">{heroSubtitle}</p>
        <a href={`/${lang}/products`} class="btn-primary">{heroCta} →</a>
      </div>
    </div>
  </section>

  <div class="folk-band"></div>

  <!-- FEATURED PRODUCTS -->
  {featured.length > 0 && (
    <section class="section featured-section">
      <span class="eyebrow">{t(lang, 'nav.products')}</span>
      <h2 class="section-title">{t(lang, 'products.title')}</h2>
      <div class="product-grid">
        {featured.map((product) => {
          const coverImage = product.entry.images?.[0] ?? null
          const title = pick(product.entry.title as any, lang)
          return (
            <a href={`/${lang}/products/${product.slug}`} class="product-card">
              <div class="product-img-wrap">
                {coverImage ? (
                  <img src={coverImage} alt={title} loading="lazy" class="product-img" />
                ) : (
                  <div class="product-img-placeholder" />
                )}
              </div>
              <div class="product-info">
                <span class="tag">{t(lang, `cat.${product.entry.category}` as any)}</span>
                <h3 class="product-name">{title}</h3>
                <span class="product-link">{t(lang, 'products.viewProduct')} →</span>
              </div>
            </a>
          )
        })}
      </div>
      <div class="all-link-wrap">
        <a href={`/${lang}/products`} class="btn-outline">{t(lang, 'products.title')} →</a>
      </div>
    </section>
  )}

  <div class="folk-band"></div>

  <!-- ABOUT TEASER -->
  <section class="about-teaser">
    <div class="about-teaser-inner section">
      <div class="about-teaser-text">
        <span class="eyebrow">{t(lang, 'about.title')}</span>
        <h2 class="section-title" style="color:#fff">Ljanlji</h2>
        <p class="about-teaser-body">
          {lang === 'bs' && 'Svaki komad nastaje u tišini, rukom i srcem. Inspiracija dolazi iz seoskog života Balkana — sa polja, iz bašte, iz tradicije koja se prenosi s koljena na koljeno.'}
          {lang === 'sr' && 'Сваки комад настаје у тишини, руком и срцем. Инспирација долази из сеоског живота Балкана — са поља, из баште, из традиције која се преноси с кољена на кољено.'}
          {lang === 'de' && 'Jedes Stück entsteht in der Stille, mit Hand und Herz. Die Inspiration kommt aus dem Landleben des Balkans — von den Feldern, aus dem Garten, aus einer Tradition, die von Generation zu Generation weitergegeben wird.'}
          {lang === 'en' && 'Every piece is made in silence, by hand and heart. The inspiration comes from rural Balkan life — from the fields, from the garden, from a tradition passed down through generations.'}
        </p>
        <a href={`/${lang}/about`} class="btn-primary" style="background:var(--mustard);color:var(--dark)">{t(lang, 'about.title')} →</a>
      </div>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="section contact-cta">
    <div class="contact-cta-inner">
      <p class="contact-cta-text">
        {lang === 'bs' && 'Zainteresovani?'}
        {lang === 'sr' && 'Заинтересовани?'}
        {lang === 'de' && 'Interessiert?'}
        {lang === 'en' && 'Interested?'}
        {' '}
        <span>
          {lang === 'bs' && 'Pišite nam.'}
          {lang === 'sr' && 'Пишите нам.'}
          {lang === 'de' && 'Schreiben Sie uns.'}
          {lang === 'en' && 'Get in touch.'}
        </span>
      </p>
      <a href={`/${lang}/contact`} class="btn-outline">{t(lang, 'contact.title')} →</a>
    </div>
  </section>
</Base>

<style>
  /* HERO */
  @property --lx {
    syntax: '<percentage>';
    inherits: false;
    initial-value: 66%;
  }
  @property --ly {
    syntax: '<percentage>';
    inherits: false;
    initial-value: 50%;
  }

  .hero {
    position: relative;
    min-height: 62vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--dark);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg-sharp {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-bg-blur {
    position: absolute;
    inset: -4%;
    width: 108%;
    height: 108%;
    filter: blur(8px);
    mask-image: radial-gradient(ellipse 46% 64% at var(--lx) var(--ly), transparent 32%, rgba(0,0,0,0.88) 60%, black 74%);
    -webkit-mask-image: radial-gradient(ellipse 46% 64% at var(--lx) var(--ly), transparent 32%, rgba(0,0,0,0.88) 60%, black 74%);
    animation: lensFloat 16s ease-in-out infinite;
  }

  .hero-bg-blur-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg, rgba(18,10,4,0.58) 0%, rgba(18,10,4,0.28) 55%, transparent 100%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 88px 48px 80px;
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .hero-text { max-width: 480px; }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    color: #fff;
    margin: 12px 0 18px;
    line-height: 1.15;
    text-shadow: 0 2px 12px rgba(0,0,0,0.45), 0 1px 3px rgba(0,0,0,0.3);
  }

  .hero-title em { color: var(--mustard); }

  .hero-sub {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.82);
    line-height: 1.75;
    margin-bottom: 30px;
    max-width: 380px;
    text-shadow: 0 1px 6px rgba(0,0,0,0.4);
  }

  .hero .eyebrow {
    color: var(--mustard);
    opacity: 0.9;
    text-shadow: 0 1px 6px rgba(0,0,0,0.4);
  }

  @keyframes lensFloat {
    0%, 100% { --lx: 42%; --ly: 52%; }
    20%       { --lx: 50%; --ly: 38%; }
    40%       { --lx: 36%; --ly: 62%; }
    60%       { --lx: 52%; --ly: 56%; }
    80%       { --lx: 34%; --ly: 40%; }
  }

  /* FEATURED */
  .featured-section { padding-top: 56px; padding-bottom: 56px; }

  .section-title {
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    color: var(--dark);
    margin-bottom: 32px;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 36px;
  }

  .product-card {
    background: #fff;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(90,144,96,0.15);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s, transform 0.2s;
    display: block;
  }

  .product-card:hover {
    box-shadow: 0 8px 28px rgba(58,32,16,0.14);
    transform: translateY(-2px);
  }

  .product-img-wrap { overflow: hidden; aspect-ratio: 4/3; }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .product-card:hover .product-img { transform: scale(1.04); }

  .product-img-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--paper) 0%, var(--brown-paper) 100%);
  }

  .product-info { padding: 14px 16px 18px; }

  .product-name {
    font-size: 16px;
    color: var(--dark);
    margin: 8px 0 10px;
  }

  .product-link {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: var(--terracotta);
    font-weight: 600;
  }

  .all-link-wrap { text-align: center; }

  /* ABOUT TEASER */
  .about-teaser {
    background: linear-gradient(135deg, var(--sage-dark) 0%, var(--sage) 100%);
  }

  .about-teaser-body {
    font-size: 0.875rem;
    color: #fff;
    opacity: 0.88;
    line-height: 1.82;
    margin-bottom: 28px;
    max-width: 520px;
  }

  /* CONTACT CTA */
  .contact-cta { padding-top: 40px; padding-bottom: 40px; }

  .contact-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    background: var(--paper);
    border-radius: var(--radius-md);
    padding: 28px 36px;
    flex-wrap: wrap;
  }

  .contact-cta-text {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    color: var(--dark);
  }

  .contact-cta-text span { color: var(--terracotta); font-style: italic; }

  @media (max-width: 768px) {
    .hero-inner { padding: 64px 20px 56px; }
    .hero-bg-blur { animation: none; mask-image: none; -webkit-mask-image: none; filter: blur(16px); }
    .product-grid { grid-template-columns: 1fr; }
    .contact-cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
