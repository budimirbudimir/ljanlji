---
export const prerender = true
import Base from '@/layouts/Base.astro'
import { t, locales, type Locale } from '@/i18n/ui'
import { pick } from '@/lib/content'
import { createReader } from '@keystatic/core/reader'
import keystaticConfig from '../../../../keystatic.config'

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params as { lang: Locale }

const reader = createReader(process.cwd(), keystaticConfig)
const allPosts = await reader.collections.blogPosts.all()
const posts = allPosts
  .filter((p) => p.entry.status === 'published')
  .sort((a, b) => (b.entry.publishedDate ?? '').localeCompare(a.entry.publishedDate ?? ''))
---

<Base locale={lang} title={t(lang, 'blog.title')}>
  <section class="section">
    <h1 class="page-title">{t(lang, 'blog.title')}</h1>
    <p class="page-sub">{t(lang, 'blog.subtitle')}</p>

    {posts.length === 0 ? (
      <p class="empty">—</p>
    ) : (
      <div class="blog-grid">
        {posts.map((post) => {
          const title = pick(post.entry.title as any, lang)
          const excerpt = pick(post.entry.excerpt as any, lang)
          return (
            <a href={`/${lang}/blog/${post.slug}`} class="blog-card">
              {post.entry.coverImage && (
                <div class="blog-card-img-wrap">
                  <img src={post.entry.coverImage} alt={title as string} loading="lazy" class="blog-card-img" />
                </div>
              )}
              <div class="blog-card-body">
                {post.entry.publishedDate && (
                  <time class="blog-date" datetime={post.entry.publishedDate}>
                    {t(lang, 'blog.published')}: {new Date(post.entry.publishedDate).toLocaleDateString(
                      lang === 'sr' ? 'sr-Cyrl' : lang === 'de' ? 'de-DE' : lang === 'en' ? 'en-GB' : 'bs',
                      { day: 'numeric', month: 'long', year: 'numeric' }
                    )}
                  </time>
                )}
                <h2 class="blog-title">{title}</h2>
                {excerpt && <p class="blog-excerpt">{excerpt}</p>}
                <span class="read-more">{t(lang, 'blog.readMore')} →</span>
              </div>
            </a>
          )
        })}
      </div>
    )}
  </section>
</Base>

<style>
  .page-title {
    font-size: clamp(28px, 4vw, 40px);
    color: var(--dark);
    margin-bottom: 8px;
  }

  .page-sub {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--mid);
    margin-bottom: 40px;
    font-style: italic;
  }

  .empty { color: var(--mid); font-style: italic; }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
  }

  .blog-card {
    display: block;
    background: #fff;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(90,144,96,0.15);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s, transform 0.2s;
    color: inherit;
  }

  .blog-card:hover {
    box-shadow: 0 8px 28px rgba(58,32,16,0.14);
    transform: translateY(-2px);
  }

  .blog-card-img-wrap { overflow: hidden; aspect-ratio: 16/9; }

  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .blog-card:hover .blog-card-img { transform: scale(1.04); }

  .blog-card-body { padding: 20px 22px 24px; }

  .blog-date {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--sage);
    text-transform: uppercase;
    display: block;
    margin-bottom: 10px;
  }

  .blog-title {
    font-size: 20px;
    color: var(--dark);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .blog-excerpt {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--mid);
    line-height: 1.7;
    margin-bottom: 14px;
  }

  .read-more {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--terracotta);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
