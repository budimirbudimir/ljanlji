---
export const prerender = true
import Base from '@/layouts/Base.astro'
import ContactForm from '@/components/ui/ContactForm'
import { t, locales, type Locale } from '@/i18n/ui'

export async function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params as { lang: Locale }
---

<Base locale={lang} title={t(lang, 'contact.title')}>
  <section class="section contact-section">
    <div class="contact-grid">
      <div class="contact-left">
        <h1 class="page-title">{t(lang, 'contact.title')}</h1>
        <p class="contact-subtitle">{t(lang, 'contact.subtitle')}</p>

        <div class="contact-info">
          <div class="contact-item">
            <span class="contact-label">{t(lang, 'contact.phone')}</span>
            <a href="tel:+38766321916" class="contact-value">{t(lang, 'contact.phonePlaceholder')}</a>
          </div>
          <div class="contact-item">
            <span class="contact-label">{t(lang, 'contact.email')}</span>
            <a href="mailto:ljiljana3777@gmail.com" class="contact-value">{t(lang, 'contact.emailPlaceholder')}</a>
          </div>
          <div class="contact-item">
            <span class="contact-label">{t(lang, 'contact.address')}</span>
            <span class="contact-value">{t(lang, 'contact.addressPlaceholder')}</span>
          </div>
        </div>

        <div class="contact-social">
          <span class="contact-label">{t(lang, 'contact.follow')}</span>
          <div class="social-row">
            <a href="https://www.facebook.com/permakulturabih/" target="_blank" rel="noopener noreferrer" class="social-pill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
              </svg>
              Facebook
            </a>
            <a href="https://www.instagram.com/ljanlji.rukotvorine" target="_blank" rel="noopener noreferrer" class="social-pill">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
              </svg>
              Instagram
            </a>
          </div>
        </div>
      </div>

      <div class="contact-right">
        <div class="form-card">
          <ContactForm
            client:load
            lang={lang}
            strings={{
              name: t(lang, 'contact.name'),
              email: t(lang, 'contact.email'),
              message: t(lang, 'contact.message'),
              send: t(lang, 'contact.send'),
              sending: t(lang, 'contact.sending'),
              success: t(lang, 'contact.success'),
              error: t(lang, 'contact.error'),
            }}
          />
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .contact-section { padding-top: 56px; padding-bottom: 80px; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 64px;
    align-items: start;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: var(--dark);
    margin-bottom: 10px;
  }

  .contact-subtitle {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--mid);
    font-style: italic;
    margin-bottom: 40px;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 40px;
  }

  .contact-item { display: flex; flex-direction: column; gap: 4px; }

  .contact-label {
    font-family: var(--font-body);
    font-size: 0.5625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sage);
    font-weight: 600;
  }

  .contact-value {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--dark);
  }

  a.contact-value { color: var(--terracotta); }
  a.contact-value:hover { text-decoration: underline; }

  .contact-social { display: flex; flex-direction: column; gap: 10px; }

  .social-row { display: flex; gap: 10px; flex-wrap: wrap; }

  .social-pill {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--dark);
    border: 1.5px solid rgba(90,144,96,0.35);
    border-radius: 20px;
    padding: 7px 14px;
    transition: border-color 0.15s, color 0.15s;
    font-weight: 600;
  }

  .social-pill:hover { border-color: var(--terracotta); color: var(--terracotta); }

  .form-card {
    background: #fff;
    border-radius: var(--radius-md);
    padding: 36px;
    border: 1px solid rgba(90,144,96,0.15);
    box-shadow: var(--shadow-hero);
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .form-card { padding: 24px 20px; }
  }
</style>
