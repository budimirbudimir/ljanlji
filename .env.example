# Resend — get a free key at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email receiving address (where contact form messages land)
CONTACT_TO=info@ljanlji.com

# "From" address — must be verified in Resend (or use @resend.dev for testing)
CONTACT_FROM=noreply@ljanlji.com

# NOTE: Made public.
# GitHub repo info for Keystatic admin in production
# GITHUB_REPO_OWNER=your-github-username
# GITHUB_REPO_NAME=ljanlji

# Keystatic GitHub OAuth App credentials
# Create at: github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL: https://ljanlji.com
# Callback URL: https://ljanlji.com/api/keystatic/github/oauth/callback
KEYSTATIC_GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
KEYSTATIC_GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Random secret for Keystatic session signing (any long random string)
KEYSTATIC_SECRET=your-random-secret-min-32-chars
